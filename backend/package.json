{
  "name": "khade-backend",
  "version": "1.0.0",
  "description": "Khade beauty platform REST API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "seed": "node src/seed.js",
    "generate": "node src/generate-data.js",
    "export-bootstrap": "node src/export-bootstrap-file.js",
    "build:videos": "node scripts/build-video-catalog.js",
    "build:catalog": "node scripts/build-pexels-catalog.js",
    "supplement:catalog": "node scripts/supplement-catalog.js",
    "rescan:videos": "node scripts/rescan-video-catalog.js",
    "import:providers": "node scripts/import-real-providers.js",
    "seed:providers": "node scripts/seed-24-providers.js && node scripts/import-real-providers.js && node scripts/seed-feed-content.js",
    "bundle:data": "node scripts/bundle-deploy-data.js",
    "migrate:supabase": "node scripts/migrate-to-supabase.js",
    "supabase:status": "node scripts/supabase-status.js",
    "supabase:migrate": "node scripts/supabase-migrate.js",
    "supabase:sync": "node scripts/supabase-migrate.js && node scripts/migrate-to-supabase.js",
    "supabase:setup": "node scripts/supabase-setup.js",
    "supabase:seed-app": "node scripts/supabase-seed-app-data.js",
    "supabase:storage": "node scripts/supabase-ensure-storage.js",
    "supabase:phase7": "node scripts/supabase-ensure-phase7.js",
    "launch:check": "node scripts/launch-check.js",
    "launch:setup": "node scripts/supabase-launch.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.16.3"
  },
  "engines": {
    "node": ">=18"
  }
}
