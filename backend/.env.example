# Copy to .env and fill in values (never commit .env)

# JWT for auth tokens (change in production)
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Paystack — get secret key from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_test_35ce59d68cc897e975dbc6fde7b33b5837b576d4

# Callback base URL — LAN IP for local dev; HTTPS Render URL for production
# Local:   http://YOUR_LAN_IP:3001
# Production: https://khade-api-xxxx.onrender.com
PAYSTACK_CALLBACK_BASE=http://YOUR_LAN_IP:3001

# Optional — free at https://www.pexels.com/api/ (builds 200+ category reel videos)
# PEXELS_API_KEY=your_pexels_api_key_here

# Optional Supabase — persistent database (recommended for production)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Anon key works for local testing only if RLS policies allow writes
# SUPABASE_ANON_KEY=your_anon_key_here
