# Khade backend — copy to .env and fill in values (never commit .env)

JWT_SECRET=change-me-long-random-string

# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
SUPABASE_ANON_KEY=eyJ...anon
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role
# Postgres URI for npm run supabase:migrate (Dashboard → Database → URI)
SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Paystack (test keys for dev)
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...
# Use Render URL in production so phones work after Paystack redirect
PAYSTACK_CALLBACK_BASE=https://khade-api.onrender.com

# Optional
KHADE_API_URL=https://khade-api.onrender.com
PEXELS_API_KEY=
